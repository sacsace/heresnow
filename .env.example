# PostgreSQL (로컬 또는 Railway Variables)
# 비밀번호에 @ # : / 등이 있으면 encodeURIComponent 로 인코딩한 뒤 URL에 넣으세요.
DATABASE_URL="postgresql://postgres:changeme@127.0.0.1:5432/heresnow?schema=public"

# NextAuth — 최소 32자 (예: openssl rand -base64 32)
AUTH_SECRET="replace-with-random-secret-at-least-32-chars-long"
AUTH_URL="http://localhost:3000"

# 프로덕션에서 프록시 뒤에 배포할 때만 true (로컬 개발은 불필요)
# AUTH_TRUST_HOST=true

# SEO 메타데이터·sitemap·robots의 절대 URL 베이스. 미지정 시 AUTH_URL 자동 사용.
# 운영 도메인이 AUTH_URL과 다를 때만 별도 지정.
# NEXT_PUBLIC_SITE_URL="https://www.heresnow.in"

# 운영용 슈퍼관리자 부트스트랩 (prisma/bootstrap.ts). 1회 실행 후 즉시 삭제 권장.
# SEED_SUPER_ADMIN_EMAIL=""
# SEED_SUPER_ADMIN_PASSWORD=""
# SEED_SUPER_ADMIN_ROTATE_PASSWORD="1"  # 기존 사용자 비밀번호도 새로 갱신할 때

# 선택: Google Static Maps (관리자 출퇴근·직원 위치 지도). 비우면 직원 화면은 iframe 임베드로 표시
# Static Map·근무지 Places 검색 — Maps JavaScript API + Places API 활성화 필요
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# MVS 출퇴근 연동 (추후 연동 시 설정)
# MVS가 HeresNow 이벤트를 가져갈 때: Authorization: Bearer {MVS_INTEGRATION_API_KEY}
MVS_INTEGRATION_API_KEY=""
# 웹훅 푸시 대상(회사별 webhookUrl 없을 때 기본값)
MVS_DEFAULT_WEBHOOK_URL=""
# MVS 웹훅 호출 시 선택 Bearer
MVS_WEBHOOK_BEARER=""
# 아웃박스 웹훅 배치: POST /api/integrations/mvs/dispatch
INTEGRATION_DISPATCH_SECRET=""

# Razorpay (결제하기)
# - 로컬 개발: dashboard.razorpay.com 테스트 키 (rzp_test_…)
# - 운영(Railway 등): Live 키 (rzp_live_…) — 호스팅 환경 변수에만 설정, git 커밋 금지
# NEXT_PUBLIC_RAZORPAY_KEY_ID 는 RAZORPAY_KEY_ID 와 동일한 Key ID
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Tax invoice — supplier (Minsub Ventures Private Limited). Invoices are English only.
INVOICE_VENDOR_LEGAL_NAME="Minsub Ventures Private Limited"
INVOICE_VENDOR_ADDRESS_LINE1="24/1, Doddanekundi, Ferns City Road, Outer Ring Road, Marathahalli, Bengaluru, Karnataka 560037"
INVOICE_VENDOR_ADDRESS_LINE2=""
INVOICE_VENDOR_CITY="Bengaluru"
INVOICE_VENDOR_STATE="Karnataka"
INVOICE_VENDOR_POSTAL_CODE="560037"
INVOICE_VENDOR_COUNTRY="India"
INVOICE_VENDOR_GSTIN=""
INVOICE_VENDOR_PAN=""
INVOICE_VENDOR_CIN=""
INVOICE_VENDOR_EMAIL="billing@minsubventures.com"
INVOICE_VENDOR_PHONE=""
INVOICE_VENDOR_WEBSITE="https://www.heresnow.in"
INVOICE_VENDOR_PRODUCT="HeresNow"
INVOICE_GST_RATE_PERCENT="18"
# GST e-Invoice number: {prefix}/{FY}/{serial} — max 16 chars (e.g. HN/2627/00001)
INVOICE_NUMBER_PREFIX="HN"

# India GST e-Invoice (IRN via GSP). B2B requires supplier + buyer GSTIN.
EINVOICE_ENABLED="false"
# Local/dev mock IRN without GSP: EINVOICE_MOCK="1"
EINVOICE_MOCK=""
EINVOICE_GSP_API_URL=""
EINVOICE_GSP_AUTH_TOKEN=""

# 고객센터 문의 메일 (SMTP — Google Workspace / Zoho / 호스팅 메일)
SUPPORT_SMTP_HOST=""
SUPPORT_SMTP_PORT="587"
SUPPORT_SMTP_SECURE="false"
SUPPORT_SMTP_USER=""
SUPPORT_SMTP_PASS=""
SUPPORT_SMTP_FROM=""
SUPPORT_TO_EMAIL="info@msventures.in"

# 로컬 DB 초기화: npm run db:setup -- -PostgresPassword "postgres비밀번호"
# 스키마 반영: npx prisma migrate deploy && npm run db:seed
