# PostgreSQL
# 로컬: 아래처럼 직접 지정
# Railway: Postgres 서비스의 DATABASE_URL을 그대로 복사 (Variables에 연결)
DATABASE_URL="postgresql://postgres:PASSWORD@127.0.0.1:5432/herenow?schema=public"

# 로컬 한 번에 준비: npm run db:setup -- -PostgresPassword "postgres계정비밀번호"
# Railway: release 단계에서 `prisma migrate deploy` 실행됨 (railway.toml). 최초 시드는 수동:
#   railway run npm run db:seed  (또는 일회성 Shell)

# NextAuth — AUTH_SECRET 필수 (openssl rand -base64 32)
# Railway 배포 URL과 동일하게 (예: https://your-app.up.railway.app)
AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3000"

# 선택: 관리자 지도 미리보기 (정적 지도 URL용)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""
