// 멀티 테넌트 출퇴근 증빙 — 모든 주요 엔티티에 companyId(또는 상위를 통한 격리) 적용

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR_MANAGER
  APPROVER
  EMPLOYEE
  /// 입구 고정 단말 — 타 직원 출퇴근 기록
  DOOR
}

enum AttendanceType {
  CHECK_IN
  CHECK_OUT
}

enum AttendanceStatus {
  APPROVED
  PENDING
  REJECTED
}

enum ExceptionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BillingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum PaymentOrderStatus {
  CREATED
  PAID
  FAILED
}

enum EInvoiceStatus {
  SKIPPED
  PENDING
  ISSUED
  FAILED
}

enum PaymentPurpose {
  SUBSCRIPTION_RENEWAL
  TIER_UPGRADE
}

/// 외부 HR/출퇴근 연동 (MVS 등)
enum IntegrationProvider {
  MVS
}

enum IntegrationOutboxStatus {
  PENDING
  DELIVERED
  FAILED
}

/// 좌석 구간 요금 (월/연 구분, 슈퍼관리자 수정)
model PricingTier {
  id             String         @id @default(cuid())
  minSeats       Int
  maxSeats       Int
  billingPeriod  BillingPeriod  @default(YEARLY)
  priceAmount    Int /// 레거시 구간 정액 (표시·호환용)
  /// 1인당 요금 — 청구 = 사용 인원 × pricePerUser (0이면 priceAmount/maxSeats 로 추정)
  pricePerUser   Int            @default(0)
  currency       String         @default("INR")
  label          String?
  /// 가입 시 구독 만료: 체험일 우선, 없으면 월/연에 따라 1개월·1년
  trialDays      Int?
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  companiesAsCurrent    Company[]        @relation("CompanyPricingTier")
  billingRequestsTarget BillingRequest[] @relation("BillingTargetTier")

  @@unique([minSeats, maxSeats, billingPeriod])
}

model BillingRequest {
  id             String               @id @default(cuid())
  companyId      String
  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  targetTierId   String
  targetTier     PricingTier          @relation("BillingTargetTier", fields: [targetTierId], references: [id], onDelete: Restrict)
  amountDue      Int /// 요청 시점 연간 요금 스냅샷 (Rs)
  status         BillingRequestStatus @default(PENDING)
  note           String?
  createdAt      DateTime             @default(now())
  resolvedAt     DateTime?
  resolverUserId String?
  resolver       User?                @relation("BillingResolver", fields: [resolverUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
}

/// Razorpay 결제 주문
model PaymentOrder {
  id                 String             @id @default(cuid())
  companyId          String
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purpose            PaymentPurpose     @default(SUBSCRIPTION_RENEWAL)
  amountPaise        Int
  currency           String             @default("INR")
  employeeCount      Int
  pricePerUser       Int
  discountTotal      Int                @default(0)
  billingPeriod      BillingPeriod
  /// 결제한 사용 개월 수 (구독 연장)
  usageMonths        Int                @default(1)
  pricingTierId      String?
  targetTierId       String?
  razorpayOrderId    String?            @unique
  razorpayPaymentId  String?
  status             PaymentOrderStatus @default(CREATED)
  paidAt             DateTime?
  /// 결제 완료 시점 고객 청구 정보 스냅샷 (인보이스용)
  invoiceCustomerSnapshot Json?
  /// GST — 할인 후 과세 금액 (paise)
  taxableAmountPaise Int?
  cgstPaise          Int                @default(0)
  sgstPaise          Int                @default(0)
  igstPaise          Int                @default(0)
  gstRatePercent     Int                @default(18)
  supplierState      String?
  customerState      String?
  /// India GST e-Invoice (IRN)
  eInvoiceStatus     EInvoiceStatus     @default(SKIPPED)
  eInvoiceIrn        String?
  eInvoiceAckNo      String?
  eInvoiceAckAt      DateTime?
  eInvoiceSignedQrCode String?
  eInvoiceLastError  String?
  /// GST tax invoice number — `{prefix}/{FY}/{serial}`, assigned at payment
  invoiceNumber      String?            @unique
  createdAt          DateTime           @default(now())

  @@index([companyId])
  @@index([status])
}

/// Sequential invoice numbers per Indian financial year (Apr–Mar).
model InvoiceNumberSequence {
  financialYear String @id
  lastSerial    Int    @default(0)
}

model Company {
  id        String   @id @default(cuid())
  name      String
  /// IANA 타임존 (지각/조퇴 판별)
  timezone  String   @default("Asia/Kolkata")
  /// false면 출근 시 안면 등록·인식 없이 GPS만으로 출근
  faceRecognitionEnabled Boolean @default(true)
  /// 회사 타임존 기준 정규 출근 "HH:mm"
  workStartTime        String?  @default("09:00")
  /// 회사 타임존 기준 정규 퇴근 "HH:mm"
  workEndTime          String?  @default("18:00")
  /// 근무 요일 (JS getDay: 0=일 … 6=토), 콤마 구분 예: "1,2,3,4,5"
  workDays             String?  @default("1,2,3,4,5")
  /// 요일별 근무시간(JSON) — {"1":{"workStartTime":"09:00","workEndTime":"18:00"}, ...}
  workScheduleByDay    Json?
  /// 3교대 프리셋(JSON) — {"A":{"label":"1교대","workStartTime":"06:00","workEndTime":"14:00"}, ...}
  shiftPresets         Json?
  /// 근무지 반경 정책: OFF | WARN | BLOCK
  geofenceMode         String   @default("OFF")
  createdAt DateTime @default(now())

  pricingTierId      String?
  pricingTier          PricingTier? @relation("CompanyPricingTier", fields: [pricingTierId], references: [id], onDelete: SetNull)
  /// 직원(Employee) 최대 수 — 요금제에 따라 상한
  seatLimit            Int          @default(20)
  subscriptionEndsAt   DateTime?
  /// 청구 할인 (%), 0–100
  billingDiscountPercent Int        @default(0)
  /// 청구 할인 (정액, Rs 등)
  billingDiscountAmount  Int        @default(0)
  /// 세금계산서(인보이스) — 법인명 (미입력 시 name 사용)
  billingLegalName       String?
  billingAddressLine1    String?
  billingAddressLine2    String?
  billingCity            String?
  billingState           String?
  billingPostalCode      String?
  billingCountry         String?    @default("India")
  /// GSTIN / Tax ID
  billingGstin           String?
  billingEmail           String?
  billingPhone           String?

  users                User[]
  employees            Employee[]
  sites                Site[]
  departments          Department[]
  attendanceRecords    AttendanceRecord[]
  attendanceExceptions AttendanceException[]
  approvalLogs         ApprovalLog[]
  billingRequests      BillingRequest[]
  paymentOrders        PaymentOrder[]
  integrations         CompanyIntegration[]
  integrationOutbox    IntegrationOutbox[]
}

/// 회사별 부서 (조직도) — 회사 내 유일한 이름
model Department {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
  siteLinks SiteDepartment[]

  @@unique([companyId, name])
  @@index([companyId])
}

/// SUPER_ADMIN은 companyId 없음 가능
model User {
  id               String    @id @default(cuid())
  companyId        String?
  company          Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email            String    @unique
  passwordHash     String
  role             Role      @default(EMPLOYEE)
  consentGivenAt   DateTime?
  consentVersion   String?
  createdAt        DateTime  @default(now())

  employee       Employee?
  approvalLogs   ApprovalLog[] @relation("ApproverUser")
  resolvedBillingRequests BillingRequest[] @relation("BillingResolver")
}

model Employee {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  /// 소속 부서 — 부서 삭제 시 직원은 미배정으로 남김(SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  /// MVS 등 외부 시스템 직원 ID
  externalEmployeeId String?
  /// 128차원 안면 임베딩(JSON 배열). 출근 시 본인 확인용
  faceDescriptor Json?
  faceEnrolledAt DateTime?
  /// COMPANY=회사 기본, SHIFT=교대(A/B/C), CUSTOM=개별 지정
  workScheduleType   String   @default("COMPANY")
  /// SHIFT 일 때 A | B | C
  shiftCode          String?
  /// CUSTOM 일 때만 사용 (회사 workDays는 그대로 적용)
  workStartTime      String?
  workEndTime        String?
  workScheduleByDay  Json?
  createdAt DateTime @default(now())

  attendanceRecords AttendanceRecord[]

  @@index([companyId])
  @@index([departmentId])
}

model Site {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  latitude       Float
  longitude      Float
  allowedRadius  Float    /// 미터 단위
  /// "HH:mm" 현지(회사 타임존) 기준, 없으면 지각/조퇴 미판별
  expectedCheckIn  String?
  expectedCheckOut String?
  /// COMPANY=회사 기본, SHIFT=교대, CUSTOM=지점 개별
  workScheduleMode String   @default("COMPANY")
  shiftCode        String?
  workStartTime    String?
  workEndTime      String?
  createdAt      DateTime @default(now())

  attendanceRecords AttendanceRecord[]
  departments       SiteDepartment[]

  @@index([companyId])
}

/// 근무지 ↔ 부서 (비어 있으면 전체 부서 공용)
model SiteDepartment {
  siteId       String
  site         Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([siteId, departmentId])
  @@index([departmentId])
}

model AttendanceRecord {
  id                 String            @id @default(cuid())
  companyId          String
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId         String
  employee           Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  /// 레거시·참고용. 위치만으로 출퇴근할 때는 null
  siteId             String?
  site               Site?             @relation(fields: [siteId], references: [id], onDelete: SetNull)
  type               AttendanceType
  timestamp          DateTime          @default(now())
  /// 출퇴근 시점 회사 IANA 타임존 — 이후 회사 설정이 바뀌어도 표시·일자는 이 값 기준
  recordTimezone     String?
  latitude           Float
  longitude          Float
  accuracy           Float?
  /// 근무지 대비 거리(m). 근무지 없음이면 0
  distanceFromSite   Float
  /// 허용 반경 밖에서 기록됨 (WARN 확인 또는 BLOCK 우회 없음)
  outsideGeofence    Boolean  @default(false)
  status             AttendanceStatus  @default(APPROVED)
  memo               String?
  /// 출장 출근 여부
  isBusinessTrip     Boolean  @default(false)
  /// 출장 지역·도시 등 명칭
  businessTripLocation String?
  /// 출장 사유
  businessTripReason String?
  photoUrl           String?
  deviceInfo         String?
  isLate             Boolean  @default(false)
  isEarlyLeave       Boolean  @default(false)
  /// 정규 퇴근 이후 퇴근(근무일)
  isOvertime         Boolean  @default(false)
  /// 비근무일(휴일) 출퇴근
  isHolidayWork      Boolean  @default(false)
  /// 지각 분 (출근 시, 근무일만, 정시 출근 기준 nowMin - workStartMin)
  lateMinutes        Int      @default(0)
  /// 초과 근무 분(퇴근 시, 근무일만)
  overtimeMinutes    Int      @default(0)

  exception AttendanceException?

  @@index([companyId])
  @@index([employeeId])
  @@index([timestamp])
}

model AttendanceException {
  id            String            @id @default(cuid())
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendanceId  String            @unique
  attendance    AttendanceRecord  @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  reason        String
  status        ExceptionStatus   @default(PENDING)
  createdAt     DateTime          @default(now())
  resolvedAt    DateTime?

  @@index([companyId])
  @@index([status])
}

model ApprovalLog {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  approverId  String
  approver    User     @relation("ApproverUser", fields: [approverId], references: [id], onDelete: Cascade)
  action      String
  targetType  String?
  targetId    String?
  timestamp   DateTime @default(now())

  @@index([companyId])
}

/// 회사별 MVS(등) 연동 설정
model CompanyIntegration {
  id                String              @id @default(cuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider          IntegrationProvider
  enabled           Boolean             @default(false)
  /// MVS 쪽 회사/테넌트 식별자
  externalCompanyId String?
  /// 출퇴근 이벤트 POST 대상 (MVS가 제공 시)
  webhookUrl        String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([companyId, provider])
  @@index([companyId])
}

/// MVS로 전달할 출퇴근 이벤트 큐 (웹훅 푸시 또는 MVS 폴링)
model IntegrationOutbox {
  id          String                  @id @default(cuid())
  companyId   String
  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider    IntegrationProvider
  eventType   String
  resourceId  String
  payload     Json
  status      IntegrationOutboxStatus @default(PENDING)
  attempts    Int                     @default(0)
  lastError   String?
  createdAt   DateTime                @default(now())
  deliveredAt DateTime?

  @@unique([provider, resourceId, eventType])
  @@index([status, createdAt])
  @@index([companyId, provider])
}
