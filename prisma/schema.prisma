// 멀티 테넌트 출퇴근 증빙 — 모든 주요 엔티티에 companyId(또는 상위를 통한 격리) 적용

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR_MANAGER
  APPROVER
  EMPLOYEE
}

enum AttendanceType {
  CHECK_IN
  CHECK_OUT
}

enum AttendanceStatus {
  APPROVED
  PENDING
  REJECTED
}

enum ExceptionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BillingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// 연간 좌석 구간 요금 (슈퍼관리자가 금액·구간 수정 가능)
model PricingTier {
  id           String   @id @default(cuid())
  minSeats     Int
  maxSeats     Int
  pricePerYear Int /// INR 등 정수 금액 (연)
  currency     String   @default("INR")
  label        String?
  /// 가입 시 구독 만료를 `now + trialDays`로 설정. null이면 1년 연장 로직(유료)
  trialDays    Int?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companiesAsCurrent    Company[]        @relation("CompanyPricingTier")
  billingRequestsTarget BillingRequest[] @relation("BillingTargetTier")

  @@unique([minSeats, maxSeats])
}

model BillingRequest {
  id             String               @id @default(cuid())
  companyId      String
  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  targetTierId   String
  targetTier     PricingTier          @relation("BillingTargetTier", fields: [targetTierId], references: [id], onDelete: Restrict)
  amountDue      Int /// 요청 시점 연간 요금 스냅샷 (Rs)
  status         BillingRequestStatus @default(PENDING)
  note           String?
  createdAt      DateTime             @default(now())
  resolvedAt     DateTime?
  resolverUserId String?
  resolver       User?                @relation("BillingResolver", fields: [resolverUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  /// IANA 타임존 (지각/조퇴 판별)
  timezone  String   @default("Asia/Seoul")
  createdAt DateTime @default(now())

  pricingTierId      String?
  pricingTier          PricingTier? @relation("CompanyPricingTier", fields: [pricingTierId], references: [id], onDelete: SetNull)
  /// 직원(Employee) 최대 수 — 요금제에 따라 상한
  seatLimit            Int          @default(20)
  subscriptionEndsAt   DateTime?

  users                User[]
  employees            Employee[]
  sites                Site[]
  attendanceRecords    AttendanceRecord[]
  attendanceExceptions AttendanceException[]
  approvalLogs         ApprovalLog[]
  billingRequests      BillingRequest[]
}

/// SUPER_ADMIN은 companyId 없음 가능
model User {
  id               String    @id @default(cuid())
  companyId        String?
  company          Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email            String    @unique
  passwordHash     String
  role             Role      @default(EMPLOYEE)
  consentGivenAt   DateTime?
  consentVersion   String?
  createdAt        DateTime  @default(now())

  employee       Employee?
  approvalLogs   ApprovalLog[] @relation("ApproverUser")
  resolvedBillingRequests BillingRequest[] @relation("BillingResolver")
}

model Employee {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  attendanceRecords AttendanceRecord[]

  @@index([companyId])
}

model Site {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  latitude       Float
  longitude      Float
  allowedRadius  Float    /// 미터 단위
  /// "HH:mm" 현지(회사 타임존) 기준, 없으면 지각/조퇴 미판별
  expectedCheckIn  String?
  expectedCheckOut String?
  createdAt      DateTime @default(now())

  attendanceRecords AttendanceRecord[]

  @@index([companyId])
}

model AttendanceRecord {
  id                 String            @id @default(cuid())
  companyId          String
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId         String
  employee           Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  /// 레거시·참고용. 위치만으로 출퇴근할 때는 null
  siteId             String?
  site               Site?             @relation(fields: [siteId], references: [id], onDelete: SetNull)
  type               AttendanceType
  timestamp          DateTime          @default(now())
  latitude           Float
  longitude          Float
  accuracy           Float?
  /// 근무지 대비 거리(m). 근무지 없음이면 0
  distanceFromSite   Float
  status             AttendanceStatus  @default(APPROVED)
  memo               String?
  photoUrl           String?
  deviceInfo         String?
  isLate             Boolean  @default(false)
  isEarlyLeave       Boolean  @default(false)

  exception AttendanceException?

  @@index([companyId])
  @@index([employeeId])
  @@index([timestamp])
}

model AttendanceException {
  id            String            @id @default(cuid())
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendanceId  String            @unique
  attendance    AttendanceRecord  @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  reason        String
  status        ExceptionStatus   @default(PENDING)
  createdAt     DateTime          @default(now())
  resolvedAt    DateTime?

  @@index([companyId])
  @@index([status])
}

model ApprovalLog {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  approverId  String
  approver    User     @relation("ApproverUser", fields: [approverId], references: [id], onDelete: Cascade)
  action      String
  targetType  String?
  targetId    String?
  timestamp   DateTime @default(now())

  @@index([companyId])
}
