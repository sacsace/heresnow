{
  "name": "heresnow",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node scripts/clean-dev.mjs && next dev",
    "build": "prisma generate && node scripts/copy-face-models.mjs && cross-env NODE_ENV=production next build",
    "start": "next start -H 0.0.0.0",
    "db:migrate:deploy": "prisma migrate deploy",
    "lint": "next lint",
    "postinstall": "prisma generate && node scripts/copy-face-models.mjs",
    "face:models": "node scripts/copy-face-models.mjs",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:bootstrap": "tsx prisma/bootstrap.ts",
    "db:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-db.ps1",
    "db:studio": "prisma studio",
    "db:verify": "npx tsx scripts/db-verify.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "exceljs": "^4.4.0",
    "leaflet": "^1.9.4",
    "next": "^15.2.8",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "^15.2.8",
    "postcss": "^8",
    "prisma": "^6.3.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
